{
  "name": "scsa-pseudocode",
  "scopeName": "source.scsa",
  "fileTypes": [
    "scsa"
  ],
  "patterns": [
    {
      "name": "comment.line.scsa",
      "match": "(//|#).*$"
    },
    {
      "name": "string.quoted.double.scsa",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.scsa",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "string.quoted.single.scsa",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.scsa",
          "match": "\\\\."
        }
      ]
    },
    {
      "name": "constant.numeric.scsa",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    {
      "name": "constant.language.boolean.scsa",
      "match": "\\b(TRUE|FALSE|True|False)\\b"
    },
    {
      "comment": "Matches Class Definitions (e.g., CLASS Animal)",
      "match": "\\b(CLASS)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "storage.type.class.scsa"
        },
        "2": {
          "name": "entity.name.type.class.scsa"
        }
      }
    },
    {
      "comment": "Matches Function Definitions (e.g., FUNCTION eat)",
      "match": "\\b(FUNCTION)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "storage.type.function.scsa"
        },
        "2": {
          "name": "entity.name.function.scsa"
        }
      }
    },
    {
      "comment": "Matches structural END statements",
      "match": "\\b(END)\\s+(IF|WHILE|FOR|CASE)\\b",
      "captures": {
        "1": {
          "name": "keyword.control.scsa"
        },
        "2": {
          "name": "keyword.control.scsa"
        }
      }
    },
    {
      "comment": "Matches named END statements (END Animal, END x) - The Edge Case",
      "match": "\\b(END)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": {
          "name": "keyword.control.scsa"
        },
        "2": {
          "name": "entity.name.function.scsa"
        }
      }
    },
    {
      "comment": "General Control Keywords",
      "name": "keyword.control.scsa",
      "match": "\\b(IF|THEN|ELSE|FOR|WHILE|UNTIL|RETURN|IN|AND|OR|NOT|CASE|OF)\\b"
    },
    {
      "comment": "Object Oriented / Storage Keywords",
      "name": "storage.modifier.scsa",
      "match": "\\b(ATTRIBUTES|Attributes|METHODS|Methods|NEW|new)\\b"
    },
    {
      "comment": "Built-in functions (like PRINT)",
      "match": "\\b(PRINT|OUTPUT)(?=\\s*\\()",
      "captures": {
        "1": {
          "name": "support.function.scsa"
        }
      }
    },
    {
      "comment": "Generic Function calls",
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()",
      "name": "entity.name.function.call.scsa"
    },
    {
      "comment": "Operators",
      "name": "keyword.operator.scsa",
      "match": "(!=|>=|<=|==|\\+|\\-|\\*|\\/|=|\\>|\\<)"
    }
  ]
}