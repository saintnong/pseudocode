{
  "FOR-IN Loop": {
    "prefix": "FOR",
    "body": [
      "FOR ${1:item} IN ${2:collection}",
      "\t$0",
      "END FOR"
    ]
  },
  "FOR-TO Loop": {
    "prefix": "FOR",
    "body": [
      "FOR ${1:variable} = ${2:start} TO ${3:end}",
      "\t$0",
      "END FOR"
    ]
  },
  "IF Statement": {
    "prefix": "IF",
    "body": [
      "IF ${1:condition} THEN",
      "\t$0",
      "END IF"
    ]
  },
  "WHILE Loop": {
    "prefix": "WHILE",
    "body": [
      "WHILE ${1:condition}",
      "\t$0",
      "END WHILE"
    ]
  },
  "Declare a FUNCTION": {
    "prefix": "FUNCTION",
    "body": [
      "FUNCTION ${1:name}(${2:params})",
      "\t$0",
      "END ${1:name}"
    ]
  },
  "Declare a CLASS": {
    "prefix": "CLASS",
    "body": [
      "CLASS ${1:name}",
      "\tATTRIBUTES",
      "\t\t$2",
      "\tMETHODS",
      "\t\t$0",
      "END ${1:name}"
    ]
  },
  "CASE Statement": {
    "prefix": "CASE",
    "body": [
      "CASE ${1:expression} OF",
      "\t${2:value}: $3",
      "\tOTHERWISE: $0",
      "END CASE"
    ]
  },
  "REPEAT-UNTIL Loop": {
    "prefix": "REPEAT",
    "body": [
      "REPEAT",
      "\t$0",
      "UNTIL ${1:condition}"
    ]
  },
  "Declare a CLASS with a Parent": {
    "prefix": "CLASS",
    "body": [
      "CLASS ${1:name} : ${2:parent}",
      "\tATTRIBUTES",
      "\t\t$3",
      "\tMETHODS",
      "\t\t$0",
      "END ${1:name}"
    ]
  }
}