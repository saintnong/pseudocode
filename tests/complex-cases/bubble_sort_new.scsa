# Old bubble sort was before arr.length was implemented
# This one is taken straight out of SCSA syllabus

FUNCTION BubbleSort(array_to_sort)
    last = array_to_sort.length - 1
    swapped = TRUE
    WHILE swapped
        swapped = FALSE
        i = 0
        WHILE i < last
            IF array_to_sort[i] > array_to_sort[i + 1] THEN
                temp = array_to_sort[i]
                array_to_sort[i] = array_to_sort[i + 1]
                array_to_sort[i + 1] = temp
                swapped = TRUE
            END IF
            i = i + 1
        END WHILE
        last = last - 1
    END WHILE
    RETURN array_to_sort
END BubbleSort


PRINT(BubbleSort([3, 4, 2, 1, 7, -9]))
# EXPECT: [-9, 1, 2, 3, 4, 7]
