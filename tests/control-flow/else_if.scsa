x = 15

IF x == 5 THEN
    PRINT("x is 5")
ELSE IF x == 10 THEN
    PRINT("x is 10")
ELSE IF x == 15 THEN
    PRINT("x is 15")
ELSE
    PRINT("x is something else")
END IF

x = 10
IF x == 1 THEN
    PRINT("x is 1")
ELSE IF x == 10 THEN
    PRINT("x is 10 again")
END IF

# EXPECT: x is 15
# EXPECT: x is 10 again
