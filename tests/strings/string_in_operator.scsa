# IN operator with strings — positive tests

# Substring found
PRINT("abc" IN "abcdef")
# EXPECT: true

# Substring not found
PRINT("xyz" IN "abcdef")
# EXPECT: false

# Empty string is always found
PRINT("" IN "abc")
# EXPECT: true

# Case sensitivity — uppercase not equal to lowercase
PRINT("ABC" IN "abc")
# EXPECT: false

# Same case match
PRINT("ABC" IN "ABCdef")
# EXPECT: true

# Full string match
PRINT("hello" IN "hello")
# EXPECT: true

# Single character
PRINT("e" IN "hello")
# EXPECT: true

PRINT("z" IN "hello")
# EXPECT: false

# Multiple occurrences — first match
PRINT("ll" IN "hello")
# EXPECT: true

# Spaces matter
PRINT(" " IN "a b")
# EXPECT: true

# Numbers as substrings
PRINT("123" IN "abc123def")
# EXPECT: true

# String longer than search space
PRINT("hello world" IN "hello")
# EXPECT: false
