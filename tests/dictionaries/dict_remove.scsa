# Dict remove method tests

# Remove existing key — length decreases
d = {"a": 1, "b": 2, "c": 3}
d.remove("a")
PRINT(d.length)
# EXPECT: 2

# Remove existing key — key no longer found via IN
PRINT("a" IN d)
# EXPECT: false

# Remove another existing key
d.remove("c")
PRINT(d.length)
# EXPECT: 1

# Remaining key still accessible
PRINT(d["b"])
# EXPECT: 2

# Remove non-existent key — silent, no error
d.remove("nonexistent")
PRINT(d.length)
# EXPECT: 1

# Remove with integer key
d2 = {1: "one", 2: "two", 3: "three"}
d2.remove(1)
PRINT(1 IN d2)
# EXPECT: false
PRINT(d2.length)
# EXPECT: 2

# Remove with boolean key
d3 = {TRUE: "yes", FALSE: "no"}
d3.remove(TRUE)
PRINT(TRUE IN d3)
# EXPECT: false
PRINT(d3.length)
# EXPECT: 1

# Remove returns Null
data = {"x": 10}
result = data.remove("x")
PRINT(result)
# EXPECT: Null

# Remove all keys — empty dict
all = {"a": 1, "b": 2}
all.remove("a")
all.remove("b")
PRINT(all.length)
# EXPECT: 0
