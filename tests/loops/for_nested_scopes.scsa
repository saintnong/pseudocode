# Test nested FOR loops inside a function with loop-body local variables
# This ensures that stack allocation/cleanup for loop-body variables is balanced correctly.

FUNCTION test_nested()
    n = 3
    C = []
    FOR i = 0 TO n - 1
        row = []
        FOR j = 0 TO n - 1
            row.append(i * 10 + j)
        END FOR
        C.append(row)
    END FOR
    RETURN C
END test_nested

res = test_nested()
PRINT(res)
# EXPECT: [[0, 1, 2], [10, 11, 12], [20, 21, 22]]
