CLASS Animal
ATTRIBUTES
    name = ""
    hunger = 5
    food_list = ["fish"]
METHODS
    FUNCTION Animal(new_name)
        PRINT("hi im an animal called", new_name)
        this.name = new_name
    END Animal

    FUNCTION eat(food)
        result = ""
        IF food IN this.food_list THEN
            result = "Not hungry"
            IF this.hunger > 0 THEN
                this.hunger = this.hunger - 1
                result = "That was yummy"
            END IF
        ELSE
            result = "I don't like that food"
        END IF
        RETURN result
    END eat

    FUNCTION is_hungry()
        RETURN hunger > 0
    END is_hungry
END Animal
@
bruh = NEW Animal("jack")
PRINT(bruh.food_list)
PRINT("hunger:")
PRINT(bruh.hunger)
PRINT(bruh.eat("fish"))
john = NEW Animal("john")
PRINT("hunger:")
PRINT(bruh.hunger)
PRINT(john.hunger)

