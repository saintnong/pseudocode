# IN operator with arrays — positive tests

# Basic membership
PRINT(3 IN [1, 2, 3])
# EXPECT: true

# Non-membership
PRINT(5 IN [1, 2, 3])
# EXPECT: false

# Empty array — nothing found
PRINT(1 IN [])
# EXPECT: false

# Mixed type array
PRINT("a" IN [1, "a", TRUE])
# EXPECT: true

# Boolean membership
PRINT(TRUE IN [FALSE, TRUE])
# EXPECT: true

PRINT(TRUE IN [1, 2, 3])
# EXPECT: false

# String in array
PRINT("hello" IN ["hello", "world"])
# EXPECT: true

PRINT("hi" IN ["hello", "world"])
# EXPECT: false

# Float in array
PRINT(3.14 IN [1.0, 2.0, 3.14])
# EXPECT: true

PRINT(9.99 IN [1.0, 2.0, 3.14])
# EXPECT: false

# Single-element array
PRINT(42 IN [42])
# EXPECT: true

PRINT(0 IN [42])
# EXPECT: false
