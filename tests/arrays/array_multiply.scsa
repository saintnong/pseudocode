# Array Multiplication

# Basic tests
PRINT([1, 2] * 3) # EXPECT: [1, 2, 1, 2, 1, 2]
PRINT(3 * ["a", "b"]) # EXPECT: [a, b, a, b, a, b]
PRINT([0] * 5) # EXPECT: [0, 0, 0, 0, 0]

# 0 and -1 give empty array
PRINT([1, 2, 3] * 0) # EXPECT: []
PRINT([1, 2, 3] * -1) # EXPECT: []

# Nested arrays
PRINT([[1]] * 2) # EXPECT: [[1], [1]]

# Ensure multiply does a shallow copy
arr = [[1]]
mult = arr * 2
PRINT(mult) # EXPECT: [[1], [1]]

# Ensure both are modified
arr[0].append(2)
PRINT(mult) # EXPECT: [[1, 2], [1, 2]]
