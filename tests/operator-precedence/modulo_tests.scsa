# Modulo positive tests for integers and floats using both '%' and 'MOD'

# Integer modulo with '%'
PRINT(10 % 3)
# EXPECT: 1

PRINT(12 % 4)
# EXPECT: 0

PRINT(-10 % 3)
# EXPECT: -1

PRINT(10 % -3)
# EXPECT: 1

# Integer modulo with 'MOD'
PRINT(10 MOD 3)
# EXPECT: 1

PRINT(12 MOD 4)
# EXPECT: 0

# Float modulo with '%'
PRINT(10.5 % 3.0)
# EXPECT: 1.5

PRINT(10.0 % 2.5)
# EXPECT: 0

# Float modulo with 'MOD'
PRINT(10.5 MOD 3.0)
# EXPECT: 1.5

# Modulo operator precedence (same as * and /, higher than + and -)
# 2 + 10 % 3 -> 2 + 1 = 3
PRINT(2 + 10 % 3)
# EXPECT: 3

# 10 % 3 + 2 -> 1 + 2 = 3
PRINT(10 % 3 + 2)
# EXPECT: 3

# 10 % (3 + 2) -> 10 % 5 = 0
PRINT(10 % (3 + 2))
# EXPECT: 0

# 2 * 10 % 3 -> 20 % 3 = 2 (left-to-right precedence)
PRINT(2 * 10 % 3)
# EXPECT: 2

# 10 % 3 * 2 -> 1 * 2 = 2 (left-to-right precedence)
PRINT(10 % 3 * 2)
# EXPECT: 2
